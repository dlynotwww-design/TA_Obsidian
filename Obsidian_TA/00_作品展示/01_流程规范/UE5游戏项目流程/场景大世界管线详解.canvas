		{"id":"edge-collab-art-to-prog","fromNode":"collab-art","fromSide":"right","toNode":"collab-prog","toSide":"left","label":"提交场景 → 需要引擎保障"},
		{"id":"edge-collab-prog-to-ta","fromNode":"collab-prog","fromSide":"bottom","toNode":"collab-cycle","toSide":"top","label":"性能数据 → TA 分析"},
		{"id":"edge-collab-ta-to-cycle","fromNode":"collab-ta","fromSide":"bottom","toNode":"collab-cycle","toSide":"top","label":"优化方案"},
		{"id":"edge-collab-art-to-cycle","fromNode":"collab-art","fromSide":"bottom","toNode":"collab-cycle","toSide":"top","label":"资产调整"},
		{"id":"edge-houdini-to-bridge","fromNode":"dataflow-houdini","fromSide":"right","toNode":"dataflow-bridge","toSide":"left","label":"RAW/FBX/USD/CSV"},
		{"id":"edge-bridge-to-ue5","fromNode":"dataflow-bridge","fromSide":"right","toNode":"dataflow-ue5","toSide":"left","label":"PCG Data Asset"},
